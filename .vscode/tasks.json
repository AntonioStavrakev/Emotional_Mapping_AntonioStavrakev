{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Emotional_Mapping_AntonioStavrakev.sln",
        "-m:1",
        "-nologo",
        "-v",
        "minimal"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "run-api-http",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Emotional_Mapping.Api/Emotional_Mapping.Api.csproj",
        "--launch-profile",
        "http"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "csharp",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "Now listening on:\\s+http://localhost:5052"
        }
      }
    },
    {
      "label": "run-web-http",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Emotional_Mapping.Web/Emotional_Mapping.Web.csproj",
        "--launch-profile",
        "http"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "csharp",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "Now listening on:\\s+http://localhost:5202"
        }
      }
    }
  ]
}
