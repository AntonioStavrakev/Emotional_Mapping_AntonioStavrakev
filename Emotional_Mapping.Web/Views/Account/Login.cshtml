@model Emotional_Mapping.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="auth-wrap fade-up">
    <div class="auth-card">
        <h1 class="auth-title">Вход в GEOFEEL</h1>
        <p class="auth-sub">Влез в профила си, за да генерираш карти, да пазиш история и да използваш premium функции.</p>

        @if (ViewBag.Error != null)
        {
            <div class="em-alert em-alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="em-form-group">
                <label asp-for="Email" class="em-label">Имейл</label>
                <input asp-for="Email" class="em-input" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="Password" class="em-label">Парола</label>
                <input asp-for="Password" type="password" class="em-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                Вход
            </button>
            @if (TempData["Error"] != null)
            {
                <div class="em-alert em-alert-error">@TempData["Error"]</div>
            }

            <div style="margin-top:18px; display:grid; gap:10px;">
                <a href="/Account/GoogleLogin" class="btn-em btn-em-ghost" style="width:100%;justify-content:center;">
                    Вход с Google
                </a>
                <a href="/Account/AppleLogin" class="btn-em btn-em-ghost" style="width:100%;justify-content:center;">
                    Вход с Apple
                </a>
            </div>
        </form>

        <div class="auth-footer">
            Нямаш профил? <a href="/Account/Register">Регистрация</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}