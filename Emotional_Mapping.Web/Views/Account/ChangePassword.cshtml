@model Emotional_Mapping.Web.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = T["Account.ChangePassword"];
}

<div class="auth-wrap fade-up">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <span style="font-size:2.5rem;">🔒</span>
        </div>
        <h1 class="auth-title">@T.Pick("Промени паролата", "Change your password")</h1>
        <p class="auth-sub">@T.Pick("Въведи текущата и новата си парола.", "Enter your current and new password.")</p>

        @if (TempData["Success"] != null)
        {
            <div class="em-alert em-alert-ok">✅ @TempData["Success"]</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="em-alert em-alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="em-form-group">
                <label asp-for="CurrentPassword" class="em-label">@T.Pick("Текуща парола", "Current password")</label>
                <input asp-for="CurrentPassword" type="password" class="em-input" placeholder="@T.Pick("Текущата ти парола", "Your current password")" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="NewPassword" class="em-label">@T.Pick("Нова парола", "New password")</label>
                <input asp-for="NewPassword" type="password" class="em-input" placeholder="@T.Pick("Минимум 6 символа", "At least 6 characters")" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="ConfirmPassword" class="em-label">@T.Pick("Потвърди новата парола", "Confirm the new password")</label>
                <input asp-for="ConfirmPassword" type="password" class="em-input" placeholder="@T.Pick("Повтори новата парола", "Repeat the new password")" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-em btn-em-primary" style="width:100%;justify-content:center;" data-busy-text="@T.Pick("Промяна...", "Updating...")">
                🔑 @T.Pick("Промени паролата", "Change password")
            </button>
        </form>

        <div class="auth-footer">
            <a href="/">← @T.Pick("Обратно към началото", "Back to home")</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
