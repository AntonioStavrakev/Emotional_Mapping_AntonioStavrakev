@{
    ViewData["Title"] = T.Pick("Проверете имейла си", "Check your email");
}

<div class="auth-wrap fade-up">
    <div class="auth-card" style="text-align:center;">
        <span style="font-size:3.5rem;display:block;margin-bottom:1rem;">📬</span>
        <h1 class="auth-title">@T.Pick("Проверете имейла си", "Check your email")</h1>
        <p class="auth-sub" style="margin-bottom:1.5rem;">
            @T.Pick("Ако имейлът е регистриран в GEOFEEL, ще получите линк за смяна на паролата в рамките на няколко минути.", "If the email is registered in GEOFEEL, you'll receive a password reset link within a few minutes.")
        </p>
        <div class="em-alert em-alert-ok" style="text-align:left;">
            📧 @Html.Raw(T.Pick("Проверете и папката <strong>Спам</strong>, ако не виждате имейла.", "Check your <strong>Spam</strong> folder too if you don't see the email."))
        </div>

        <div style="margin-top:2rem;">
            <a href="/Account/Login" class="btn-em btn-em-primary" style="justify-content:center;">
                @T.Pick("Обратно към вход", "Back to sign in")
            </a>
        </div>

        <div class="auth-footer" style="margin-top:1.5rem;">
            <a href="/Account/ForgotPassword">@T.Pick("Опитай отново с друг имейл", "Try again with another email")</a>
        </div>
    </div>
</div>
