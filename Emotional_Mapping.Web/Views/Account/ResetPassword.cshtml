@model Emotional_Mapping.Web.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = T.Pick("Нова парола", "New password");
}

<div class="auth-wrap fade-up">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <span style="font-size:2.5rem;">🔐</span>
        </div>
        <h1 class="auth-title">@T.Pick("Задай нова парола", "Set a new password")</h1>
        <p class="auth-sub">@T.Pick("Въведи и потвърди новата си парола.", "Enter and confirm your new password.")</p>

        @if (ViewBag.Error != null)
        {
            <div class="em-alert em-alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div class="em-form-group">
                <label asp-for="NewPassword" class="em-label">@T.Pick("Нова парола", "New password")</label>
                <input asp-for="NewPassword" type="password" class="em-input" placeholder="@T.Pick("Минимум 6 символа", "At least 6 characters")" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="ConfirmPassword" class="em-label">@T.Pick("Потвърди паролата", "Confirm password")</label>
                <input asp-for="ConfirmPassword" type="password" class="em-input" placeholder="@T.Pick("Повтори новата парола", "Repeat the new password")" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                ✅ @T.Pick("Запази новата парола", "Save new password")
            </button>
        </form>

        <div class="auth-footer">
            <a href="/Account/Login">← @T.Pick("Обратно към вход", "Back to sign in")</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
