@model Emotional_Mapping.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-wrap fade-up">
    <div class="auth-card">
        <h1 class="auth-title">Регистрация в GEOFEEL</h1>
        <p class="auth-sub">Създай профил и започни да генерираш емоционални карти с AI.</p>

        @if (ViewBag.Error != null)
        {
            <div class="em-alert em-alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="em-form-group">
                <label asp-for="Email" class="em-label">Имейл</label>
                <input asp-for="Email" class="em-input" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="Password" class="em-label">Парола</label>
                <input asp-for="Password" type="password" class="em-input" placeholder="Минимум 6 символа" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="em-form-group">
                <label asp-for="ConfirmPassword" class="em-label">Потвърди паролата</label>
                <input asp-for="ConfirmPassword" type="password" class="em-input" placeholder="Повтори паролата" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                Регистрация
            </button>
        </form>

        <div class="auth-footer">
            Вече имаш профил? <a href="/Account/Login">Вход</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}