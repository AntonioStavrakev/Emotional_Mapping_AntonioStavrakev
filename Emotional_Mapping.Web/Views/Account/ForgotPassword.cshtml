@model Emotional_Mapping.Web.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = T.Pick("Забравена парола", "Forgot password");
}

<div class="auth-wrap fade-up">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <span style="font-size:2.5rem;">🔑</span>
        </div>
        <h1 class="auth-title">@T.Pick("Забравена парола", "Forgot password")</h1>
        <p class="auth-sub">@T.Pick("Въведи имейл адреса си и ще ти изпратим линк за смяна на паролата.", "Enter your email and we'll send you a password reset link.")</p>

        @if (ViewBag.Error != null)
        {
            <div class="em-alert em-alert-error">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="em-form-group">
                <label asp-for="Email" class="em-label">@T.Pick("Имейл адрес", "Email address")</label>
                <input asp-for="Email" class="em-input" placeholder="name@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-em btn-em-primary" style="width:100%;justify-content:center;" data-busy-text="@T.Pick("Изпращане...", "Sending...")">
                📧 @T.Pick("Изпрати линк за смяна", "Send reset link")
            </button>
        </form>

        <div class="auth-footer">
            <a href="/Account/Login">← @T.Pick("Обратно към вход", "Back to sign in")</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
