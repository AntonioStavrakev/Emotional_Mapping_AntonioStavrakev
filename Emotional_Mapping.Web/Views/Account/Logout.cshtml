@{
    ViewData["Title"] = "Изход";
}

<div style="text-align:center;padding:5rem 2rem;" class="fade-up">
    <div style="font-size:3rem;margin-bottom:1.5rem;">&#128075;</div>
    <h1 style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.8rem;letter-spacing:-.03em;margin-bottom:.75rem;">
        Излизане...
    </h1>
    <p style="color:#6b7080;font-size:.95rem;margin-bottom:2rem;">Моля изчакай.</p>

    <form id="logoutForm" method="post" asp-controller="Account" asp-action="Logout">
        @Html.AntiForgeryToken()
    </form>
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('logoutForm').submit();
    });
</script>
}