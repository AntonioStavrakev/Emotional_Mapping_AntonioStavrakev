@{
ViewData["Title"] = "Моите карти";
}

<div class="em-page-header fade-up">
    <h1 class="em-page-title">Моите карти</h1>
    <p class="em-page-sub">История на генерираните от теб емоционални карти.</p>
</div>

<div id="mapsGrid" class="maps-grid fade-up fade-up-1"></div>

@section Scripts {
<script>
    const grid = document.getElementById('mapsGrid');

    fetch('/api/maps/mine')
        .then(async r => {
            if (r.status === 401) {
                grid.innerHTML = '<div class="empty"><div class="empty__icon">🔒</div><div class="empty__title">Влез в профила си</div></div>';
                return [];
            }
            return r.ok ? await r.json() : [];
        })
        .then(items => {
            if (!items.length) {
                grid.innerHTML = `
                <div class="empty">
                    <div class="empty__icon">🗺️</div>
                    <div class="empty__title">Още нямаш запазени карти</div>
                    <a href="/Map/Generate" class="btn-em btn-em-primary">Генерирай първата си карта</a>
                </div>`;
                return;
            }

            grid.innerHTML = items.map(m => `
            <a class="mcard" href="/Map/Result?mapId=${m.id}">
                <div class="mcard__hdr">
                    <div class="mcard__title">${m.title ?? 'Карта'}</div>
                    <span class="em-badge em-badge-super">${m.dominantEmotion ?? '—'}</span>
                </div>
                <div class="mcard__summ">${m.summary ?? 'Няма описание.'}</div>
                <div>
                    <small class="text-muted">Confidence</small>
                    <div class="cbar"><div class="cbar__fill" style="width:${Math.round((m.confidence ?? 0) * 100)}%"></div></div>
                </div>
                <div class="mcard__foot">
                    <small>${formatDate(m.generatedAtUtc)}</small>
                    <span class="btn-em btn-em-ghost btn-em-sm">Отвори</span>
                </div>
            </a>
        `).join('');
        });

    function formatDate(v) {
        if (!v) return '';
        return new Date(v).toLocaleString('bg-BG');
    }
</script>
}