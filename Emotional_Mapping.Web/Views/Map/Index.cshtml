@{
ViewData["Title"] = "Карта";
}

@section Styles {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

<div class="em-page-header fade-up">
    <h1 class="em-page-title">Публична емоционална карта</h1>
    <p class="em-page-sub">Разгледай публични карти и общи емоционални точки по градове.</p>
</div>

<div class="em-card fade-up fade-up-1" style="margin-bottom:18px;">
    <div class="em-form-group" style="max-width:360px;margin-bottom:0;">
        <label class="em-label">Град</label>
        <select id="citySelect" class="em-select">
            <option value="">Избери град</option>
        </select>
    </div>
</div>

<div class="map-wrap fade-up fade-up-2">
    <div class="gen-preview map-soft" style="min-height:620px;">
        <div id="mapCanvas" style="width:100%;height:620px;"></div>
    </div>

    <aside class="filter-panel">
        <div class="filter-panel__title">Публични карти</div>
        <div id="publicMapsList" class="filter-list"></div>
    </aside>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const citySelect = document.getElementById('citySelect');
    const publicMapsList = document.getElementById('publicMapsList');

    const map = L.map('mapCanvas').setView([42.6977, 23.3219], 7);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        maxZoom: 19
    }).addTo(map);

    let mapMarkers = [];

    fetch('/api/cities')
        .then(r => r.json())
        .then(cities => {
            (cities || []).forEach(c => {
                const o = document.createElement('option');
                o.value = c.id;
                o.textContent = c.name;
                o.dataset.lat = c.center?.lat ?? c.latitude ?? c.lat ?? '';
                o.dataset.lng = c.center?.lng ?? c.longitude ?? c.lng ?? '';
                citySelect.appendChild(o);
            });
        });

    citySelect.addEventListener('change', loadPublicMaps);

    async function loadPublicMaps() {
        const cityId = citySelect.value;
        if (!cityId) return;

        const opt = citySelect.options[citySelect.selectedIndex];
        if (opt.dataset.lat && opt.dataset.lng) {
            map.setView([+opt.dataset.lat, +opt.dataset.lng], 12, { animate: true });
        }

        mapMarkers.forEach(m => map.removeLayer(m));
        mapMarkers = [];
        publicMapsList.innerHTML = '';

        const r = await fetch('/api/maps/public?cityId=' + cityId);
        const maps = r.ok ? await r.json() : [];

        if (!maps.length) {
            publicMapsList.innerHTML = '<div class="fi">Няма публични карти</div>';
            return;
        }

        maps.forEach(m => {
            const el = document.createElement('a');
            el.className = 'fi';
            el.href = '/Map/Result?mapId=' + m.id;
            el.innerHTML = `<span class="cdot" style="background:#89d957"></span> ${m.title ?? 'Карта'}`;
            publicMapsList.appendChild(el);

            if (m.recommendations) {
                m.recommendations.forEach(rec => {
                    if (rec.place?.lat && rec.place?.lng) {
                        const marker = L.marker([rec.place.lat, rec.place.lng]).addTo(map)
                            .bindPopup(`<strong>${rec.place.name}</strong><br>${rec.reason ?? ''}`);
                        mapMarkers.push(marker);
                    }
                });
            }
        });
    }
</script>
}