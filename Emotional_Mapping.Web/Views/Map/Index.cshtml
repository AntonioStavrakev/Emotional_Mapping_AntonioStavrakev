@{
    ViewData["Title"] = "Емоционална карта";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<div class="em-page-header fade-up">
    <h1 class="em-page-title">Обща емоционална карта</h1>
    <p class="em-page-sub">Всички публични точки в реално време</p>
</div>

<div class="top4 fade-up fade-up-1">
    <div class="stat-card">
        <div class="stat-card__label">Общо точки</div>
        <div class="stat-card__value" id="stTotal">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Доминираща емоция</div>
        <div class="stat-card__value" id="stDom" style="font-size:1.3rem;">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Потребители</div>
        <div class="stat-card__value" id="stUsers">—</div>
    </div>
</div>

<div class="map-wrap fade-up fade-up-2">
    <div id="map" style="height:560px;border-radius:14px;border:1px solid rgba(255,255,255,.07);"></div>

    <div>
        <div class="filter-panel">
            <div class="filter-panel__title">Филтър по емоция</div>
            <div class="filter-list">
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Joy" checked/>
                    <span class="cdot" style="background:#f6c948"></span>&#128516; Радост
                </label>
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Calm" checked/>
                    <span class="cdot" style="background:#5bc8c2"></span>&#128524; Спокойствие
                </label>
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Sadness" checked/>
                    <span class="cdot" style="background:#6382c8"></span>&#128546; Носталгия
                </label>
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Anger" checked/>
                    <span class="cdot" style="background:#e85555"></span>&#128545; Напрежение
                </label>
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Fear" checked/>
                    <span class="cdot" style="background:#9c6ee8"></span>&#128552; Страх
                </label>
                <label class="fi on">
                    <input type="checkbox" class="ef" value="Romantic" checked/>
                    <span class="cdot" style="background:#e87090"></span>&#128149; Романтика
                </label>
            </div>
            <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,.07);font-size:.8rem;color:#6b7080;">
                Щракни върху маркер за детайли.
                @if (User.Identity == null || !User.Identity.IsAuthenticated)
                {
                    <br/>
                    <a href="/Account/Register" style="color:#7c6ff7;text-decoration:none;">
                        Регистрирай се, за да добавяш точки.
                    </a>
                    
                }
            </div>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="em-card" style="margin-top:1.25rem;">
                <div class="em-card__title">Бързи действия</div>
                <div style="display:flex;flex-direction:column;gap:.6rem;">
                    <a href="/Map/Generate" class="btn-em btn-em-primary" style="justify-content:center;">
                        &#129302; Генерирай карта
                    </a>
                    <a href="/Map/AddPlace" class="btn-em btn-em-ghost" style="justify-content:center;">
                        &#128205; Добави място
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var lmap = L.map('map').setView([42.15, 24.75], 12);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
    { attribution: '&copy;CartoDB', maxZoom: 19 }).addTo(lmap);

var ml  = L.layerGroup().addTo(lmap);
var pts = [];
var ec  = { Joy:'#f6c948', Calm:'#5bc8c2', Sadness:'#6382c8', Anger:'#e85555', Fear:'#9c6ee8', Romantic:'#e87090' };

function mkIcon(em) {
    var c = ec[em] || '#7c6ff7';
    return L.divIcon({
        className: '',
        html: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="34" viewBox="0 0 26 34">'
            + '<circle cx="13" cy="13" r="12" fill="' + c + '" fill-opacity=".2" stroke="' + c + '" stroke-width="2"/>'
            + '<circle cx="13" cy="13" r="5" fill="' + c + '"/></svg>',
        iconSize: [26, 34], iconAnchor: [13, 32], popupAnchor: [0, -32]
    });
}

function refresh() {
    ml.clearLayers();
    var sel = Array.from(document.querySelectorAll('.ef:checked')).map(function(x) { return x.value; });
    pts.filter(function(p) { return sel.includes(p.emotion); }).forEach(function(p) {
        var lat = p.latitude || p.lat;
        var lng = p.longitude || p.lng;
        if (!lat) return;
        L.marker([lat, lng], { icon: mkIcon(p.emotion) })
         .bindPopup('<strong style="color:#e8eaf0">' + esc(p.title || 'Без заглавие') + '</strong>'
             + '<div style="font-size:.78rem;color:#aaa;margin:.3rem 0">' + esc(p.emotion) + ' &bull; Инт. ' + (p.intensity || '—') + '</div>'
             + (p.note ? '<div style="font-size:.78rem;color:#888">' + esc(p.note) + '</div>' : ''))
         .addTo(ml);
    });
}

fetch('/api/stats?cityId=00000000-0000-0000-0000-000000000000')
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(s) {
        if (!s) return;
        document.getElementById('stTotal').textContent = s.totalPoints || '—';
        document.getElementById('stDom').textContent   = s.dominantEmotion || '—';
        document.getElementById('stUsers').textContent = s.totalUsers || '—';
    }).catch(function() {});

fetch('/api/points?cityId=00000000-0000-0000-0000-000000000000')
    .then(function(r) { return r.ok ? r.json() : []; })
    .then(function(data) {
        pts = data || [];
        refresh();
        var b = pts.filter(function(p) { return p.latitude || p.lat; })
                   .map(function(p) { return [p.latitude || p.lat, p.longitude || p.lng]; });
        if (b.length > 1) lmap.fitBounds(b, { padding: [40, 40], maxZoom: 14 });
    }).catch(function() {});

document.querySelectorAll('.ef').forEach(function(cb) {
    cb.addEventListener('change', function() {
        this.closest('.fi').classList.toggle('on', this.checked);
        refresh();
    });
});

function esc(s) {
    return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
</script>
}