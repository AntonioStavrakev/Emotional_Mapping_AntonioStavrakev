@model Emotional_Mapping.Application.DTOs.GenerateMapResultDto
@{
    Layout = "_Layout";
}

<h2>@Model.Title</h2>

<script>
    function getSelectedEmotions() {
        return Array.from(document.querySelectorAll(".emotion-filter:checked"))
            .map(cb => cb.value);
    }

    function refreshMarkers() {
        markerLayer.clearLayers();
        const selected = getSelectedEmotions();

        recommendations
            .filter(r => selected.includes(r.emotion))
            .forEach(r => {
                const marker = L.marker([r.lat, r.lng])
                    .bindPopup(`<b>${r.name}</b><br/>${r.reason}`);
                markerLayer.addLayer(marker);
            });
    }

    document.querySelectorAll(".emotion-filter").forEach(cb => {
        cb.addEventListener("change", refreshMarkers);
    });

    refreshMarkers();
</script>
<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">AI анализ</h5>
        <p><strong>Доминираща емоция:</strong> @Model.DominantEmotion</p>
        <p><strong>Обобщение:</strong> @Model.Summary</p>
    </div>
</div>
<div class="mb-3">
    <button id="enableAddPoint" class="btn btn-outline-primary">Добави емоционална точка</button>
</div>
<script>
    let addPointMode = false;

    document.getElementById("enableAddPoint").addEventListener("click", function() {
        addPointMode = !addPointMode;
        this.textContent = addPointMode ? "Изключи режим за добавяне" : "Добави емоционална точка";
    });

    map.on("click", function(e) {
        if (!addPointMode) return;

        const lat = e.latlng.lat;
        const lng = e.latlng.lng;

        const emotion = prompt("Въведи емоция (Calm, Joy, Romantic...)");
        const note = prompt("Кратко описание");

        fetch("/api/points", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                cityId: "@ViewBag.CityId",
                lat: lat,
                lng: lng,
                emotion: emotion,
                intensity: 3,
                note: note
            })
        }).then(r => {
            if (r.ok) alert("Точката е добавена.");
            else alert("Грешка при добавяне.");
        });
    });
</script>
<div class="mb-3">
    <button id="showRoute" class="btn btn-outline-success">Покажи AI маршрут</button>
</div>
<script>
    let routeLine = null;

    document.getElementById("showRoute").addEventListener("click", function() {
        const coords = recommendations.slice(0, 3).map(r => [r.lat, r.lng]);

        if (routeLine) map.removeLayer(routeLine);

        routeLine = L.polyline(coords, { color: 'blue' }).addTo(map);
        map.fitBounds(routeLine.getBounds());
    });
</script>
<div class="mb-3">
    <button id="publishMap" class="btn btn-warning">Публикувай карта</button>
    <input type="text" id="shareLink" class="form-control mt-2" readonly />
</div>
<script>
    document.getElementById("publishMap").addEventListener("click", async function() {
        const mapId = "@ViewBag.MapId";

        const response = await fetch(`/api/maps/${mapId}/publish`, {
            method: "POST"
        });

        if (!response.ok) {
            alert("Грешка при публикуване.");
            return;
        }

        const data = await response.json();
        document.getElementById("shareLink").value = window.location.origin + data.publicUrl;
    });
</script>
<div class="mb-3">
    <label class="form-label">AI увереност</label>
    <div class="progress">
        <div class="progress-bar" role="progressbar" style="width:@((int)(Model.Confidence * 100))%">
            @((int)(Model.Confidence * 100))%
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-3">
        <h5>Филтри по емоции</h5>
        <div>
            <label><input type="checkbox" class="emotion-filter" value="Calm" checked /> Спокойствие</label><br />
            <label><input type="checkbox" class="emotion-filter" value="Joy" checked /> Радост</label><br />
            <label><input type="checkbox" class="emotion-filter" value="Romantic" checked /> Романтично</label><br />
            <label><input type="checkbox" class="emotion-filter" value="Energetic" checked /> Енергично</label><br />
            <label><input type="checkbox" class="emotion-filter" value="Inspiration" checked /> Вдъхновение</label><br />
        </div>
    </div>

    <div class="col-md-9">
        <div id="map" style="height: 550px;"></div>
    </div>
</div>
<div class="mb-3">
    <strong>Доминираща емоция:</strong> @Model.DominantEmotion <br />
    <strong>AI обобщение:</strong> @Model.Summary
</div>

<div class="mb-3">
    <label>
        <input type="checkbox" id="toggleMarkers" checked />
        Покажи препоръчаните места
    </label>
    <label class="ms-3">
        <input type="checkbox" id="toggleHeatmap" checked />
        Покажи heatmap
    </label>
</div>

<div id="map" style="height: 550px; border-radius: 10px;"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>

<script>
    const map = L.map('map').setView([42.6977, 23.3219], 12);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19
    }).addTo(map);

    const recommendations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Recommendations));
    const heatData = @Html.Raw(Model.HeatmapJson ?? "[]");

    const markerLayer = L.layerGroup();
    const markerList = [];

    recommendations.forEach(r => {
        const marker = L.marker([r.lat, r.lng])
            .bindPopup(`
                <b>${r.name}</b><br/>
                Тип: ${r.type}<br/>
                Емоция: ${r.emotion}<br/>
                Причина: ${r.reason}
            `);

        markerLayer.addLayer(marker);
        markerList.push(marker);
    });

    markerLayer.addTo(map);

    let heatLayer = L.heatLayer(heatData, {
        radius: 25,
        blur: 18,
        maxZoom: 17
    }).addTo(map);

    document.getElementById("toggleMarkers").addEventListener("change", function() {
        if (this.checked) {
            map.addLayer(markerLayer);
        } else {
            map.removeLayer(markerLayer);
        }
    });

    document.getElementById("toggleHeatmap").addEventListener("change", function() {
        if (this.checked) {
            map.addLayer(heatLayer);
        } else {
            map.removeLayer(heatLayer);
        }
    });

    if (markerList.length > 0) {
        const group = new L.featureGroup(markerList);
        map.fitBounds(group.getBounds().pad(0.2));
    }
</script>