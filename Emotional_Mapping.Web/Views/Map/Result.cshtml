@{
    ViewData["Title"] = "Резултат";
}

@section Styles {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

<div class="em-page-header fade-up">
    <h1 class="em-page-title">Резултат от AI карта</h1>
    <p class="em-page-sub">Детайли, препоръки, confidence score и публичен линк.</p>
</div>

<div id="alertBox"></div>

<div class="res-grid fade-up fade-up-1">
    <div class="gen-preview" style="min-height:620px;">
        <div id="resultMap" style="width:100%;height:620px;"></div>
    </div>

    <aside class="sidebar">
        <div class="ai-card">
            <div class="ai-card__lbl">Заглавие</div>
            <div class="ai-card__val" id="mapTitle">—</div>

            <div style="margin-top:16px;">
                <div class="ai-card__lbl">Доминираща емоция</div>
                <div id="mapEmotion" class="ai-card__val" style="font-size:1.2rem;">—</div>
            </div>

            <div style="margin-top:16px;">
                <div class="ai-card__lbl">Confidence</div>
                <div id="mapConfidence" class="ai-card__val" style="font-size:1.2rem;">0%</div>
                <div class="conf-bar"><div id="confFill" class="conf-bar__fill" style="width:0%"></div></div>
            </div>

            <div style="margin-top:16px;">
                <div class="ai-card__lbl">Summary</div>
                <div id="mapSummary" style="color:var(--muted);font-size:.92rem;">—</div>
            </div>
        </div>

        <div class="ai-card">
            <div class="ai-card__lbl">Действия</div>
            <div class="acts">
                <button id="publicBtn" class="btn-em btn-em-primary btn-em-sm">Направи публична</button>
                <button id="copyBtn" class="btn-em btn-em-ghost btn-em-sm">Копирай линк</button>
            </div>
            <div id="publicLinkBox" style="font-size:.83rem;color:var(--muted);word-break:break-all;"></div>
        </div>

        <div class="ai-card">
            <div class="ai-card__lbl">Препоръки</div>
            <div id="recommendationsBox" class="rec-list"></div>
        </div>

        <div class="ai-card">
            <div class="ai-card__lbl">Обратна връзка</div>
            <div class="acts">
                <button class="vote-btn" onclick="vote(true)">👍 Точно ми пасва</button>
                <button class="vote-btn" onclick="vote(false)">👎 Не пасва</button>
            </div>
        </div>
    </aside>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const params = new URLSearchParams(window.location.search);
const mapId = params.get('mapId');

const resultMap = L.map('resultMap').setView([42.6977, 23.3219], 7);
L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap &copy; CARTO',
    maxZoom: 19
}).addTo(resultMap);

let loadedMap = null;
let loadedPublicLink = '';

if (mapId) loadResult(mapId);

async function loadResult(id) {
    const r = await fetch('/api/maps/' + id);
    if (!r.ok) {
        showAlert('error', 'Картата не беше намерена.');
        return;
    }

    const d = await r.json();
    loadedMap = d;

    document.getElementById('mapTitle').textContent = d.title ?? 'Карта';
    document.getElementById('mapEmotion').textContent = d.dominantEmotion ?? '—';
    document.getElementById('mapSummary').textContent = d.summary ?? 'Няма описание.';
    document.getElementById('mapConfidence').textContent = Math.round((d.confidence ?? 0) * 100) + '%';
    document.getElementById('confFill').style.width = Math.round((d.confidence ?? 0) * 100) + '%';

    const recs = d.recommendations ?? [];
    const box = document.getElementById('recommendationsBox');

    if (!recs.length) {
        box.innerHTML = '<div class="rec-item">Няма препоръки.</div>';
    } else {
        box.innerHTML = recs.map((x, i) => `
            <div class="rec-item" onclick="focusRec(${i})">
                <div class="rec-item__name">${x.place?.name ?? 'Място'}</div>
                <div class="rec-item__reason">${x.reason ?? ''}</div>
            </div>
        `).join('');
    }

    const bounds = [];
    recs.forEach(x => {
        const lat = x.place?.lat;
        const lng = x.place?.lng;
        if (lat && lng) {
            L.marker([lat, lng]).addTo(resultMap)
                .bindPopup(`<strong>${x.place.name}</strong><br>${x.reason ?? ''}`);
            bounds.push([lat, lng]);
        }
    });

    if (bounds.length) {
        resultMap.fitBounds(bounds, { padding: [40, 40] });
    }

    if (d.publicSlug) {
        loadedPublicLink = window.location.origin + '/api/maps/public/' + d.publicSlug;
        document.getElementById('publicLinkBox').textContent = loadedPublicLink;
    }
}

function focusRec(index) {
    const rec = loadedMap?.recommendations?.[index];
    if (!rec?.place?.lat || !rec?.place?.lng) return;
    resultMap.setView([rec.place.lat, rec.place.lng], 15);
}

async function vote(isAccurate) {
    if (!mapId) return;
    const r = await fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            generatedMapId: mapId,
            isAccurate: isAccurate,
            note: isAccurate ? 'Пасва' : 'Не пасва'
        })
    });

    if (r.ok) showAlert('ok', 'Благодарим за обратната връзка!');
    else showAlert('error', 'Неуспешно изпращане на feedback.');
}

document.getElementById('publicBtn').addEventListener('click', async () => {
    if (!mapId) return;

    const r = await fetch('/api/maps/' + mapId + '/make-public', { method: 'POST' });
    if (!r.ok) {
        showAlert('error', 'Неуспешно публикуване.');
        return;
    }

    const d = await r.json();
    loadedPublicLink = window.location.origin + '/api/maps/public/' + d.publicSlug;
    document.getElementById('publicLinkBox').textContent = loadedPublicLink;
    showAlert('ok', 'Картата вече е публична.');
});

document.getElementById('copyBtn').addEventListener('click', async () => {
    if (!loadedPublicLink) {
        showAlert('warn', 'Още няма публичен линк. Направи картата публична първо.');
        return;
    }

    await navigator.clipboard.writeText(loadedPublicLink);
    showAlert('ok', 'Линкът е копиран.');
});

function showAlert(type, message) {
    const cls = type === 'ok' ? 'em-alert-ok' :
                type === 'warn' ? 'em-alert-warn' : 'em-alert-error';

    document.getElementById('alertBox').innerHTML =
        `<div class="em-alert ${cls}">${message}</div>`;
}
</script>
}