@{
    ViewData["Title"] = "Начало";
}

<section class="hero fade-up">
    <div>
        <p class="hero__eyebrow">GEOFEEL • AI emotional mapping</p>
        <h1 class="hero__title">
            Усети града<br />
            през <span>емоциите</span><br />
            на хората
        </h1>

        <p class="hero__desc">
            GEOFEEL визуализира спокойствие, радост, носталгия, вдъхновение и още
            емоции върху реална карта. Генерирай персонална карта с AI, запази я,
            сподели я и открий най-подходящите места според настроението си.
        </p>

        <div class="hero__actions">
            <a href="/Map/Generate" class="btn-em btn-em-primary">Генерирай карта с AI</a>
            <a href="/Map" class="btn-em btn-em-ghost">Разгледай картата</a>
        </div>
    </div>

    <div class="hero__visual fade-up fade-up-2">
        <div class="emotion-cloud">
            <div class="e e1">Спокойствие</div>
            <div class="e e2">Радост</div>
            <div class="e e3">Вдъхновение</div>
            <div class="e e4">Романтика</div>
            <div class="e e5">Носталгия</div>
            <div class="e e6">Релакс</div>
            <div class="e e7">Еуфория</div>
        </div>
    </div>
</section>

<div class="fade-up fade-up-2">
    <h2 class="section-title">Как работи?</h2>
    <div class="features">
        <div class="feature-card">
            <div class="feature-card__icon">📍</div>
            <div class="feature-card__title">Добавяй емоционални точки</div>
            <p class="feature-card__desc">Маркирай място, избери емоция, интензитет и описание.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🤖</div>
            <div class="feature-card__title">AI анализ</div>
            <p class="feature-card__desc">Въведи настроение и системата ще генерира карта и препоръки.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🗺️</div>
            <div class="feature-card__title">Интерактивна карта</div>
            <p class="feature-card__desc">Визуализирай места, heatmap и емоционални зони.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">☁️</div>
            <div class="feature-card__title">Cloud база данни</div>
            <p class="feature-card__desc">Картите и точките се пазят в облачна база, достъпна отвсякъде.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🔗</div>
            <div class="feature-card__title">Публични карти</div>
            <p class="feature-card__desc">Споделяй карта с линк и показвай резултата на други хора.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">⭐</div>
            <div class="feature-card__title">Обратна връзка</div>
            <p class="feature-card__desc">Оценявай дали картата отговаря на настроението ти.</p>
        </div>
    </div>
</div>

<div class="fade-up fade-up-3">
    <h2 class="section-title">Планове</h2>
    <div class="plans">
        <div class="plan-card">
            <p class="plan-card__name">Free</p>
            <p class="plan-card__price">0 € <span>/ месец</span></p>
            <ul class="plan-features">
                <li>До 10 AI генерации на ден</li>
                <li>Стандартен heatmap</li>
                <li>Запазване на карти</li>
                <li>Добавяне на точки</li>
            </ul>
            <a href="/Account/Register" class="btn-em btn-em-ghost" style="width:100%;justify-content:center;">
                Безплатен старт
            </a>
        </div>

        <div class="plan-card plan-card--featured">
            <div class="plan-card__top">
                <p class="plan-card__name">SuperUser</p>
                <span class="em-badge em-badge-super">Premium</span>
            </div>

            <p class="price-premium">0.20 €</p>
            <p class="price-note">еднократен стартов тестов план</p>

            <ul class="plan-features">
                <li>До 100 AI генерации на ден</li>
                <li>Premium heatmap</li>
                <li>District scores</li>
                <li>Saved routes</li>
                <li>Публични линкове</li>
            </ul>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <button onclick="upgradeToPremium()" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                    Надгради със Stripe
                </button>
            }
            else
            {
                <a href="/Account/Register" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                    Започни сега
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function upgradeToPremium() {
    fetch('/api/payments/create-checkout', { method: 'POST' })
        .then(r => r.json())
        .then(d => { if (d.url) window.location.href = d.url; })
        .catch(() => alert('Моля, влез в профила си.'));
}
</script>
}