@{
    ViewData["Title"] = "Начало";
}

<section class="hero fade-up">
    <div>
        <p class="hero__eyebrow">AI-powered emotional analytics</p>
        <h1 class="hero__title">
            Картографирай<br/><span>емоциите</span> на<br/>твоя град
        </h1>
        <p class="hero__desc">
            Emotional Map визуализира как хората се чувстват в различни части на
            града — с AI анализ, интерактивен heatmap и персонализирани маршрути.
        </p>
        <div class="hero__actions">
            <a href="/Map/Generate" class="btn-em btn-em-primary">Генерирай карта с AI</a>
            <a href="/Map"          class="btn-em btn-em-ghost">Разгледай картата</a>
        </div>
    </div>
    <div class="hero__visual fade-up fade-up-2">
        <div class="emotion-cloud">
            <div class="e" style="width:88px;height:88px;background:rgba(91,200,194,.2);border:2px solid #5bc8c2;top:40px;left:8px;animation-delay:0s;">Спокойствие</div>
            <div class="e" style="width:68px;height:68px;background:rgba(246,201,72,.2);border:2px solid #f6c948;top:8px;left:125px;animation-delay:.8s;">Радост</div>
            <div class="e" style="width:74px;height:74px;background:rgba(124,111,247,.2);border:2px solid #7c6ff7;top:128px;left:88px;animation-delay:1.6s;">Вдъхновение</div>
            <div class="e" style="width:58px;height:58px;background:rgba(232,112,144,.2);border:2px solid #e87090;top:152px;left:8px;animation-delay:.4s;">Романтика</div>
            <div class="e" style="width:54px;height:54px;background:rgba(99,130,200,.2);border:2px solid #6382c8;top:78px;left:205px;animation-delay:1.2s;">Носталгия</div>
        </div>
    </div>
</section>

<div class="fade-up fade-up-2">
    <h2 class="section-title">Как работи?</h2>
    <div class="features">
        <div class="feature-card">
            <div class="feature-card__icon">&#128205;</div>
            <div class="feature-card__title">Добавяй емоционални точки</div>
            <p class="feature-card__desc">Маркирай места с емоция, интензитет 1–5 и описание. Анонимно или публично.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">&#129302;</div>
            <div class="feature-card__title">AI анализ на настроението</div>
            <p class="feature-card__desc">Въведи настроение на текст или избери от списък. AI генерира персонална карта.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">&#127777;</div>
            <div class="feature-card__title">Heatmap визуализация</div>
            <p class="feature-card__desc">Топлинна карта и AI препоръки за маршрути съобразени с настроението.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">&#11088;</div>
            <div class="feature-card__title">„Точно ми пасва"</div>
            <p class="feature-card__desc">Оценявай препоръчаните места. Оценките подобряват AI модула с времето.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">&#128190;</div>
            <div class="feature-card__title">Облачно съхранение</div>
            <p class="feature-card__desc">Всички карти и точки в облачна MySQL база данни — достъпни отвсякъде.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">&#128279;</div>
            <div class="feature-card__title">Споделяй карти</div>
            <p class="feature-card__desc">Публикувай карта с уникален линк и я сподели с приятели.</p>
        </div>
    </div>
</div>

<div class="fade-up fade-up-3">
    <h2 class="section-title">Роли в системата</h2>
    <div class="roles-grid">
        <div class="role-card">
            <div class="role-card__icon">&#128065;</div>
            <div class="role-card__name">Гост</div>
            <p class="role-card__desc">Вижда общата карта и статистики без регистрация.</p>
        </div>
        <div class="role-card">
            <div class="role-card__icon">&#128100;</div>
            <div class="role-card__name">Потребител</div>
            <p class="role-card__desc">Генерира карти, добавя точки, оценява места.</p>
        </div>
        <div class="role-card">
            <div class="role-card__icon">&#128737;</div>
            <div class="role-card__name">Модератор</div>
            <p class="role-card__desc">Преглежда и премахва неподходящо съдържание.</p>
        </div>
        <div class="role-card">
            <div class="role-card__icon">&#9889;</div>
            <div class="role-card__name">Администратор</div>
            <p class="role-card__desc">Пълен контрол — потребители, AI, статистики.</p>
        </div>
    </div>
</div>

<div class="fade-up fade-up-4">
    <h2 class="section-title">Планове</h2>
    <div class="plans">
        <div class="plan-card">
            <p class="plan-card__name">Free</p>
            <p class="plan-card__price">€0 <span>/ месец</span></p>
            <ul class="plan-features">
                <li>До 10 AI генерации на ден</li>
                <li>Стандартен heatmap</li>
                <li>Запазване на карти</li>
                <li>Добавяне на точки</li>
                <li>Оценяване на места</li>
            </ul>
            @if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                <a href="/Account/Register" class="btn-em btn-em-ghost"
                   style="width:100%;justify-content:center;">
                    Регистрирай се безплатно
                </a>
            }
        </div>
        <div class="plan-card plan-card--featured">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.5rem;">
                <p class="plan-card__name">SuperUser</p>
                <span class="em-badge em-badge-super">Платен</span>
            </div>
            <p class="plan-card__price">€0.20 <span>/ месец</span></p>
            <ul class="plan-features">
                <li>До 100 AI генерации на ден</li>
                <li>Premium heatmap + district scores</li>
                <li>AI инсайти и прогнози</li>
                <li>Споделяне с публичен линк</li>
                <li>Запазени маршрути</li>
            </ul>
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <button onclick="upgradeToPremium()" class="btn-em btn-em-primary"
                        style="width:100%;justify-content:center;">
                    &#9889; Надгради с Stripe
                </button>
            }
            else
            {
                <a href="/Account/Register" class="btn-em btn-em-primary"
                   style="width:100%;justify-content:center;">
                    Започни сега
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function upgradeToPremium() {
    fetch('/api/payments/create-checkout', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) { if (d.url) window.location.href = d.url; })
        .catch(function() { alert('Моля влезте в профила си.'); });
}
</script>
}