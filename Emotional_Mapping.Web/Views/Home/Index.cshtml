@using System.Text.Json
@using Microsoft.AspNetCore.Html
@model Emotional_Mapping.Web.Models.HomeIndexViewModel
@using Emotional_Mapping.Domain.Enums

@functions {
IHtmlContent Js(object value) => Html.Raw(JsonSerializer.Serialize(value));
}
@{
    ViewData["Title"] = T["Nav.Home"];
    var isPremium = User?.IsInRole("SuperUser") == true || User?.IsInRole("Admin") == true;
}

<section class="hero fade-up">
    <div>
        <p class="hero__eyebrow">@T["Hero.Eyebrow"]</p>
        <h1 class="hero__title">
            @T["Hero.TitleLine1"]<br />
            <span>@T["Hero.TitleAccent"]</span><br />
            @T["Hero.TitleLine3"]
        </h1>

        <p class="hero__desc">@T["Hero.Desc"]</p>

        <div class="hero__actions">
            <a href="/Map/Generate" class="btn-em btn-em-primary">@T["Hero.Primary"]</a>
            <a href="/Map" class="btn-em btn-em-ghost">@T["Hero.Secondary"]</a>
        </div>
    </div>

    <div class="hero__visual fade-up fade-up-2">
        <div class="emotion-cloud" id="emotionCloud" aria-live="polite">
            @for (var i = 0; i < Model.HeroEmotionKeys.Count; i++)
            {
                var emotionKey = Model.HeroEmotionKeys[i];
                var label = emotionKey;

                if (Enum.TryParse<EmotionType>(emotionKey, true, out var emotionType))
                {
                    label = T.EmotionLabel(emotionType);
                }

                <div class="e e@(i + 1)">@label</div>
            }
        </div>
    </div>
</section>

<div class="fade-up fade-up-2">
    <h2 class="section-title">@T["Home.HowItWorks"]</h2>
    <div class="features">
        <div class="feature-card">
            <div class="feature-card__icon">📍</div>
            <div class="feature-card__title">@T["Home.Feature1Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature1Desc"]</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🤖</div>
            <div class="feature-card__title">@T["Home.Feature2Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature2Desc"]</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🗺️</div>
            <div class="feature-card__title">@T["Home.Feature3Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature3Desc"]</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">☁️</div>
            <div class="feature-card__title">@T["Home.Feature4Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature4Desc"]</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">🔗</div>
            <div class="feature-card__title">@T["Home.Feature5Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature5Desc"]</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">⭐</div>
            <div class="feature-card__title">@T["Home.Feature6Title"]</div>
            <p class="feature-card__desc">@T["Home.Feature6Desc"]</p>
        </div>
    </div>
</div>

<div class="fade-up fade-up-3" id="plans">
    <h2 class="section-title">@T["Plans.Title"]</h2>
    <div class="plans">
        <div class="plan-card">
            <p class="plan-card__name">@T.Pick("Безплатен", "Free")</p>
            <p class="plan-card__price">0 € <span>/ @T.Pick("месец", "month")</span></p>
            <ul class="plan-features">
                <li>@T["Plans.FreeLimit"]</li>
                <li>@T["Plans.FreeFeature2"]</li>
                <li>@T["Plans.FreeFeature3"]</li>
                <li>@T["Plans.FreeFeature4"]</li>
            </ul>
            <a href="/Account/Register" class="btn-em btn-em-ghost" style="width:100%;justify-content:center;">
                @T["Plans.FreeCta"]
            </a>
        </div>

        <div class="plan-card plan-card--featured">
            <div class="plan-card__top">
                <p class="plan-card__name">Premium</p>
                <span class="em-badge em-badge-super">Premium</span>
            </div>

            <p class="price-premium">0.50 €</p>
            <p class="price-note">@T["Plans.PriceNote"]</p>

            <ul class="plan-features">
                <li>@T["Plans.PremiumLimit"]</li>
                <li>@T["Plans.PremiumFeature2"]</li>
                <li>@T["Plans.PremiumFeature3"]</li>
                <li>@T["Plans.PremiumFeature4"]</li>
                <li>@T["Plans.PremiumFeature5"]</li>
            </ul>

            @if (User.Identity?.IsAuthenticated == true)
            {
                if (isPremium)
                {
                    <button id="upgradePremiumBtn" class="btn-em btn-em-primary" style="width:100%;justify-content:center;" disabled aria-disabled="true">
                        @T["Plans.AlreadyPremium"]
                    </button>
                }
                else
                {
                    <button id="upgradePremiumBtn" onclick="upgradeToPremium()" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                        @T["Plans.Upgrade"]
                    </button>
                }
            }
            else
            {
                <a href="/Account/Register" class="btn-em btn-em-primary" style="width:100%;justify-content:center;">
                    @T["Plans.PremiumCta"]
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
const heroEmotionCacheKey = 'geofeel.heroTopEmotions';
const initialHeroEmotionKeys = @Js(Model.HeroEmotionKeys);
const heroBubbles = [
    { selector: '.e1', x: 34, y: -24, speed: 0.75, phase: 0.2, scale: 0.04, rotate: 6 },
    { selector: '.e2', x: -24, y: 28, speed: 0.92, phase: 1.1, scale: 0.03, rotate: -5 },
    { selector: '.e3', x: 30, y: 20, speed: 0.62, phase: 2.2, scale: 0.04, rotate: 7 },
    { selector: '.e4', x: -28, y: -22, speed: 0.84, phase: 3.0, scale: 0.03, rotate: -8 },
    { selector: '.e5', x: 26, y: -30, speed: 0.7, phase: 4.1, scale: 0.04, rotate: 5 },
    { selector: '.e6', x: -18, y: 24, speed: 1.05, phase: 5.0, scale: 0.03, rotate: -6 },
    { selector: '.e7', x: 22, y: 26, speed: 0.8, phase: 2.7, scale: 0.04, rotate: 6 }
];
const emotionCloud = document.getElementById('emotionCloud');

function localizeHeroEmotion(emotionKey) {
    if (!emotionKey) return '';

    if (window.GeoFeelI18n && typeof window.GeoFeelI18n.emotion === 'function') {
        return window.GeoFeelI18n.emotion(emotionKey);
    }

    return emotionKey;
}

function renderHeroBubbles(emotionKeys) {
    if (!emotionCloud) return;

    const validKeys = Array.isArray(emotionKeys)
        ? emotionKeys.filter(Boolean).slice(0, 7)
        : [];

    emotionCloud.innerHTML = '';

    validKeys.forEach((emotionKey, index) => {
        const bubble = document.createElement('div');
        bubble.className = `e e${index + 1}`;
        bubble.textContent = localizeHeroEmotion(emotionKey);
        emotionCloud.appendChild(bubble);
    });
}

function persistHeroBubbles(emotionKeys) {
    try {
        if (Array.isArray(emotionKeys) && emotionKeys.length) {
            localStorage.setItem(heroEmotionCacheKey, JSON.stringify(emotionKeys.slice(0, 7)));
        }
    } catch (_) { }
}

function loadCachedHeroBubbles() {
    try {
        const raw = localStorage.getItem(heroEmotionCacheKey);
        if (!raw) return [];

        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed.filter(Boolean).slice(0, 7) : [];
    } catch (_) {
        return [];
    }
}

async function refreshHeroBubblesIfNeeded() {
    if (!emotionCloud) return;
    if (emotionCloud.children.length > 0) return;

    const cachedKeys = loadCachedHeroBubbles();
    if (cachedKeys.length) {
        renderHeroBubbles(cachedKeys);
    }

    try {
        const response = await fetch('/api/stats/dashboard');
        if (!response.ok) return;

        const data = await response.json();
        const topKeys = Array.isArray(data?.topEmotions)
            ? data.topEmotions
                .filter(x => x && x.emotion && Number(x.count) > 0)
                .slice(0, 7)
                .map(x => x.emotion)
            : [];

        if (topKeys.length) {
            renderHeroBubbles(topKeys);
            persistHeroBubbles(topKeys);
        }
    } catch (_) { }
}

function animateHeroBubbles(timeMs) {
    const t = timeMs / 1000;

    heroBubbles.forEach(cfg => {
        const el = document.querySelector(cfg.selector);
        if (!el) return;

        const x = Math.sin(t * cfg.speed + cfg.phase) * cfg.x;
        const y = Math.cos(t * (cfg.speed * 0.87) + cfg.phase) * cfg.y;
        const scale = 1 + Math.sin(t * (cfg.speed * 1.2) + cfg.phase) * cfg.scale;
        const rotate = Math.sin(t * cfg.speed + cfg.phase) * cfg.rotate;

        el.style.transform = `translate3d(${x}px, ${y}px, 0) scale(${scale}) rotate(${rotate}deg)`;
    });

    requestAnimationFrame(animateHeroBubbles);
}

if (initialHeroEmotionKeys.length) {
    persistHeroBubbles(initialHeroEmotionKeys);
}

refreshHeroBubblesIfNeeded();
requestAnimationFrame(animateHeroBubbles);

const premiumTexts = {
    alreadyPremium: @Js(T["Plans.AlreadyPremium"]),
    checkoutFailed: @Js(T.Pick("Неуспешно стартиране на Stripe checkout.", "Failed to start Stripe checkout.")),
    checkoutUrlMissing: @Js(T.Pick("Stripe не върна checkout URL.", "Stripe did not return a checkout URL.")),
    networkError: @Js(T.Pick("Мрежова грешка при връзка със Stripe.", "Network error while contacting Stripe."))
};

function lockPremiumButton(message) {
    const button = document.getElementById('upgradePremiumBtn');
    if (!button) return;

    if (window.GeoFeelUi && typeof window.GeoFeelUi.lockButton === 'function') {
        window.GeoFeelUi.lockButton(button, premiumTexts.alreadyPremium);
    } else {
        button.disabled = true;
        button.innerHTML = premiumTexts.alreadyPremium;
    }

    button.setAttribute('aria-disabled', 'true');

    if (message) {
        button.title = message;
    }
}

async function syncPremiumButtonState() {
    const button = document.getElementById('upgradePremiumBtn');
    if (!button || button.disabled) return;

    try {
        const response = await fetch('/api/maps/quota');
        if (!response.ok) return;

        const data = await response.json();
        if (data?.isPremium) {
            lockPremiumButton(premiumTexts.alreadyPremium);
        }
    } catch (_) { }
}

syncPremiumButtonState();

function upgradeToPremium() {
    const button = document.getElementById('upgradePremiumBtn');
    const locked = !window.GeoFeelUi || window.GeoFeelUi.beginButtonAction(
        button,
        @Js(T.Pick("Пренасочване към плащане...", "Redirecting to payment..."))
    );

    if (!locked) {
        return;
    }

    fetch('/api/payments/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productType: 'premium' })
    })
        .then(async r => {
            const d = await r.json().catch(() => null);
            if (!r.ok) {
                if (d?.alreadyPremium) {
                    lockPremiumButton(d?.message || premiumTexts.alreadyPremium);
                    return;
                }

                alert(d?.message || premiumTexts.checkoutFailed);
                if (window.GeoFeelUi) {
                    window.GeoFeelUi.endButtonAction(button);
                }
                return;
            }

            if (d?.url) {
                window.location.href = d.url;
            } else {
                alert(premiumTexts.checkoutUrlMissing);
                if (window.GeoFeelUi) {
                    window.GeoFeelUi.endButtonAction(button);
                }
            }
        })
        .catch(() => {
            alert(premiumTexts.networkError);
            if (window.GeoFeelUi) {
                window.GeoFeelUi.endButtonAction(button);
            }
        });
}
</script>
}
