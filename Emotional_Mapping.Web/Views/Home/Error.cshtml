@model Emotional_Mapping.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = T.Pick("Грешка", "Error");
}

<div style="text-align:center;padding:5rem 2rem;" class="fade-up">
    <div style="font-size:4rem;margin-bottom:1.5rem;">&#9888;</div>
    <h1 style="font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;letter-spacing:-.03em;margin-bottom:.75rem;">
        @T.Pick("Нещо се обърка", "Something went wrong")
    </h1>
    <p style="color:#6b7080;margin-bottom:2rem;font-size:.95rem;">
        @T.Pick("Съжаляваме. Опитай пак или се върни към началото.", "Sorry about that. Try again or go back to the home page.")
    </p>
    @if (Model?.ShowRequestId == true)
    {
        <p style="color:#6b7080;font-size:.78rem;margin-bottom:1.5rem;">
            Request ID:
            <code style="color:#7c6ff7;background:#1c2030;padding:.2rem .5rem;border-radius:4px;">
                @Model.RequestId
            </code>
        </p>
    }
    <div style="display:flex;gap:1rem;justify-content:center;">
        <a href="/"                         class="btn-em btn-em-primary">&#8592; @T.Pick("Към начало", "Home")</a>
        <a href="javascript:history.back()" class="btn-em btn-em-ghost">@T.Pick("Назад", "Back")</a>
    </div>
</div>
